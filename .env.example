# =============================================
# AWS Credentials
# =============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================
# AI Services Configuration
# =============================================
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
OPENAI_API_KEY=

# =============================================
# Application Configuration
# =============================================
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
VP_FORM_URL=https://your-vpbank-form-url.com

# =============================================
# Connection Pool Configuration (for ECS/Fargate)
# =============================================
# Enable warm-up mode: pre-initialize connections on startup
# This reduces cold-start from 60-120s to 50-100ms
WARM_UP_MODE=true

# Initialize connection pool
# Pool size: number of connections to keep ready
# For small traffic: 2-3 connections
# For medium traffic: 3-5 connections
# For high traffic: 5-10 connections
INIT_CONNECTION_POOL=true
CONNECTION_POOL_SIZE=3

# =============================================
# WebRTC Configuration
# =============================================
# Using free TURN server (openrelay.metered.ca) - no additional config needed
# This allows WebRTC to work in Docker with only port 7860 exposed
# No need to expose UDP port range 32000-65000